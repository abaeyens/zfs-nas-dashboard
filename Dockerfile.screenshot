FROM node:22-bookworm-slim@sha256:80fdb3f57c815e1b638d221f30a826823467c4a56c8f6a8d7aa091cd9b1675ea

WORKDIR /app

COPY scripts/package.json scripts/
RUN cd scripts && npm install && \
    npx --prefix scripts playwright install chromium --with-deps

COPY scripts/screenshot.js scripts/

ENTRYPOINT ["node", "scripts/screenshot.js"]
